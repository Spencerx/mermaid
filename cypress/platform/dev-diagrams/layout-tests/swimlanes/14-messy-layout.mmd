swimlane TD

subgraph Requestor
  1([START])
  2[Creates a Purchase Request in Approvals]
  3[Submits the PR for Approval]
  15[Creates an EAF Request]
  16[Sets the Purchase Request field]
  17[Fills out the Expense line based on information given]
  18[Submits the EAF for Approval]
  24[Inform Supply Chain Associate regarding the approved EAF <br/> Note: Log Note in PR Request]
  36[Receives the Delivered Items]
  39([END])
end

subgraph Department_Head [Department Head]
  4[Reviews and Approve the PR]
  19[Reviews and Approves the EAF]
end

subgraph Supply_Chain_Associate [Supply Chain Associate]
  5[Approves the PR]
  6[Creates a Request for Quotation based on the PR]
  7{Needs canvassing?}
  8[Creates 2 or more alternative RFQs]
  9[Sends all RFQs]
  11[Update the RFQs based on the supplier's response]
  12[Submits the RFQs for Approval]
  25[Submit chosen RFQ for Approval]
  29[Sends the PO to the Supplier]
  35[Sets the Requestor as Responsible in Receipt Transfer]
  38[Forwards SI and DR to Requestor <br/> Note: Log Note in PR Request]
end

subgraph Supplier
  10[Responds to the RFQs]
  30[Responds to the PO]
  31[Delivers the Goods]
  32{Delivery Location}
  37[Sends SI and DR to Supply Chain Associate]
end

subgraph Supply_Chain_Head [Supply Chain Head]
  13[Reviews and Approves all RFQs]
  14[Inform requestor for all information needed for EAF <br/> Note: Log Note in PR Request]
  26[Reviews and Approves the chosen RFQ]
end

subgraph General_Manager [General Manager]
  20[Reviews and Approves the EAF]
  28[Reviews and Approves the chosen RFQ <br/> Note: RFQ will be converted to PO]
end

subgraph Finance_Manager [Finance Manager]
  21[Reviews and Approves the EAF]
end

subgraph BOD
  22[Reviews and Approves the EAF]
  23[Suggest the best Supplier based on all RFQs <br/> Note: Log Note in EAF Request]
end

subgraph Finance_Head [Finance Head]
  27[Reviews and Approves the chosen RFQ]
end

subgraph Warehouse
  33{Trade or Non-Trade Goods?}
  33a[[Perform     - Receiving Trade Goods]]
  33b[[Perform  - Receiving Non-Trade Goods]]
end

